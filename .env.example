# このファイルを .env にコピーして値を埋める:  cp .env.example .env
# .env は .gitignore 済み(秘密情報なのでGitHubに上げない)。

# 公開するドメイン名 (例: llm.example.com)。
# ローカル検証だけなら Caddyfile をローカル用に切り替えて、ここは空でも可。
DOMAIN=llm.example.com

# Open WebUI のセッション暗号鍵。ランダムな文字列を入れる。
# 生成例:  openssl rand -hex 32
WEBUI_SECRET_KEY=change-me-to-a-long-random-string

# Grafana の管理者パスワード。
GRAFANA_PASSWORD=change-me
